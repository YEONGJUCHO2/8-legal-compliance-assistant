# Production environment — copy to Vercel project secrets.
# ALL values must be real before production boot. Missing values fail-closed at startup.

# Postgres: use managed provider (Supabase / Neon / AWS RDS). Connection string must include sslmode=require.
DATABASE_URL=

# open.law.go.kr OpenAPI key (apply at https://open.law.go.kr). Required for law sync.
LAW_API_KEY=

# korean-law-mcp deployment URL (https). Runtime citation verification target.
KOREAN_LAW_MCP_URL=
# Shared bearer token for app -> korean-law-mcp.
# Generate with: openssl rand -hex 32
KOREAN_LAW_MCP_AUTH_TOKEN=

# Engine selection. "anthropic" for production, "codex_stub" only in dev.
ENGINE_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Optional — only if ENGINE_PROVIDER=codex_stub (not recommended in production).
CODEX_DAEMON_URL=
# Shared bearer token for app -> codex daemon.
# Generate with: openssl rand -hex 32
CODEX_DAEMON_AUTH_TOKEN=

# Absolute base URL — used in magic-link generation. Must match production domain.
APP_BASE_URL=

# Auth. AUTH_SECRET: 64+ bytes of cryptographic randomness. Rotate via `openssl rand -base64 64`.
AUTH_SECRET=
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_FROM_EMAIL=

# SMTP URL for magic-link delivery. Examples:
#   smtps://user:pass@smtp.sendgrid.net:465
#   smtp://user:pass@smtp.mailgun.org:587 (STARTTLS enforced)
SMTP_URL=

# Internal metrics endpoint gate. Rotate periodically. Must be non-empty in production.
METRICS_ACCESS_TOKEN=

# Stage deadline budgets. Sum (+ safety margin) must be <= ROUTE_MAX_DURATION_SECONDS * 1000.
QUERY_REWRITE_DEADLINE_MS=10000
RETRIEVAL_CANDIDATE_CAP=5
RETRIEVAL_DEADLINE_MS=3000
ENGINE_DEADLINE_MS=25000
MCP_VERIFY_DEADLINE_MS=8000
ROUTE_MAX_DURATION_SECONDS=60
DEADLINE_SAFETY_MARGIN_MS=2000
